{
  "name": "hannaex",
  "version": "1.0.0",
  "description": "Bot de Discord",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "copy:assets": "copyfiles -u 1 \"src/**/*.{json,sql,env,txt,md,png,jpg,jpeg,webp,svg,ico}\" dist",
    "postbuild": "npm run copy:assets",
    "start": "node dist/index.js",
    "dev": "nodemon --exec \"ts-node --transpile-only\" src/index.ts",
    "deploy:guild": "NODE_ENV=staging node dist/scripts/deploy-commands.js",
    "deploy:dev": "NODE_ENV=development node dist/scripts/deploy-commands.js",
    "deploy:global": "NODE_ENV=production node dist/scripts/deploy-commands.js --global",
    "full-deploy:staging": "npm run build && npm run deploy:guild && npm run start:staging && npm run logs:staging",
    "full-deploy:prod": "npm run build && npm run deploy:global && npm run start:prod && npm run logs:prod",
    "start:staging": "pm2 startOrRestart ecosystem.config.js --only Hoshiko-Staging",
    "start:prod": "pm2 startOrRestart ecosystem.config.js --only Hoshiko-Production --update-env",
    "stop:all": "pm2 delete all",
    "logs": "pm2 logs",
    "logs:staging": "pm2 logs Hoshiko-Staging",
    "logs:prod": "pm2 logs Hoshiko-Production",
    "monit": "pm2 monit",
    "check:reply": "ts-node src/scripts/checkReply.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@napi-rs/canvas": "^0.1.90",
    "axios": "^1.12.2",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "genius-lyrics": "^4.4.7",
    "mongodb": "^6.18.0",
    "mongoose": "^8.17.1",
    "ms": "^2.1.3",
    "node-cron": "^4.2.1",
    "pm2": "^6.0.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.10.9",
    "@types/node-cron": "^3.0.11",
    "copyfiles": "^1.0.0",
    "nodemon": "^3.1.10",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
